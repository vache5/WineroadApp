EXTERNAL_API_BASE_URL=
NEXT_PUBLIC_PRODUCTION_URL=

# Wineroad API (Express). Used for admin API calls from the browser and for server-side login proxy.
# Example production: https://api.wineroad.am
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: server-only origin for proxying (Docker/internal). Defaults to NEXT_PUBLIC_API_URL.
# BACKEND_URL=http://127.0.0.1:4000

# Optional: canonical public site URL (e.g. https://wineroad.am). Same app can be served on admin.wineroad.am
# with the same env; only DNS/hosting differs.